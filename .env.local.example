# ============================================================
# 1DotDev LOCAL .env — full secrets for WSL/local deployment
# ============================================================
# Copy this file to bridge/.env inside the 1DotDev repo and fill in real values.
# chmod 600 bridge/.env — never commit it.
#
# CRITICAL: Do NOT add AWS_REGION. Its absence tells secrets.js to
# skip AWS SSM and read everything directly from this file.
# ============================================================

# --- Meta / WhatsApp Cloud API ---
# From: developers.facebook.com/apps → 1DotDev → WhatsApp → API Setup
META_WA_PHONE_NUMBER_ID='<phone-number-id-from-meta>'

# From: Meta Business Suite → Users → System Users → Generate token
# Scopes: whatsapp_business_messaging + whatsapp_business_management, Never expires
META_WA_TOKEN='<paste-permanent-system-user-token>'

# From: Meta Business Settings → WhatsApp Accounts → your WABA → Settings
META_WA_BUSINESS_ACCOUNT_ID='<waba-id-from-meta>'

# You choose this value — any random 32-char string works.
# You will enter the SAME value in the Meta developer portal when registering the webhook.
META_WEBHOOK_VERIFY_TOKEN='<pick-any-32-char-random-string>'

# From: developers.facebook.com/apps → 1DotDev → Settings → Basic → App Secret
META_APP_SECRET='<meta-app-basic-settings-app-secret>'

# --- Anthropic ---
# From: console.anthropic.com → API Keys (set a $5/mo hard spend cap on this key)
ANTHROPIC_API_KEY='<sk-ant-...>'
ANTHROPIC_MODEL='claude-haiku-4-5'

# --- Access control ---
# Comma-separated WhatsApp numbers. No + prefix. No spaces around commas.
# Example: '15551234567,919987654321'
ALLOWED_WHATSAPP_NUMBERS='<comma-separated-numbers-no-plus>'
ADMIN_WHATSAPP_NUMBERS='<admin-number-no-plus>'

# --- Bridge port (optional, default 3000) ---
# PORT=3000

# ============================================================
# DO NOT ADD:
#   AWS_REGION         ← its absence skips SSM (intentional)
#   AWS_ACCESS_KEY_ID  ← not needed locally
#   AWS_SECRET_ACCESS_KEY ← not needed locally
# ============================================================
