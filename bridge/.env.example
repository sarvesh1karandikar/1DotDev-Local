# Meta WhatsApp Cloud API
META_WA_TOKEN=your_permanent_system_user_token_here
META_WA_PHONE_NUMBER_ID=123456789
META_WEBHOOK_VERIFY_TOKEN=your_verification_token_here
META_APP_SECRET=your_app_secret_here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-7

# Planning vs execution model override (optional)
# ANTHROPIC_PLANNING_MODEL=claude-opus-4-7
# LOCAL_EXECUTION_MODEL=http://localhost:11434

# WhatsApp Allowlist & Admin
ALLOWED_WHATSAPP_NUMBERS=16175551234,919876543210
ADMIN_WHATSAPP_NUMBERS=16175551234

# Server
PORT=3000

# Arr Stack APIs (Sonarr, Radarr, Lidarr)
SONARR_URL=http://localhost:8989
SONARR_API_KEY=your_sonarr_api_key_here

RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key_here

LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=your_lidarr_api_key_here

PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=your_prowlarr_api_key_here

# Database (local SQLite path)
DB_PATH=./data.db

# Web Search (Searxng - free, privacy-focused metasearch)
SEARXNG_URL=https://searxng.railway.app

# Local Model (Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# Model routing preferences
USE_LOCAL_ANALYZER=true
LOCAL_MODEL_FALLBACK=haiku
